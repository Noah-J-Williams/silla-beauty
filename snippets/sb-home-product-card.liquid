{% comment %}
  Editorial product card for the redesigned homepage product carousel.

  Accepts:
  - product: Product object
  - button_label: CTA label
  - loading: Image loading strategy
  - placeholder_index: Optional placeholder number when product is blank
{% endcomment %}

{%- assign image_loading = loading | default: 'lazy' -%}
{%- assign cta_label = button_label | default: 'Add to list' -%}

{%- if product != blank -%}
  <article class="sb-product-card">
    <a class="sb-product-card__media" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
      {%- if product.featured_media != blank -%}
        {{
          product.featured_media
          | image_url: width: 900
          | image_tag:
            class: 'sb-product-card__image',
            widths: '260, 360, 520, 720, 900',
            sizes: '(min-width: 990px) calc((100vw - 14rem) / 5), (min-width: 750px) calc((100vw - 7rem) / 3), 72vw',
            loading: image_loading,
            alt: product.featured_media.alt | default: product.title | escape
        }}
      {%- else -%}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'sb-product-card__placeholder placeholder-svg' }}
      {%- endif -%}
    </a>

    <div class="sb-product-card__content">
      <h3 class="sb-product-card__title">
        <a href="{{ product.url }}">{{ product.title | escape }}</a>
      </h3>

      <div class="sb-product-card__price">
        {% render 'price', product: product %}
      </div>

      <a class="sb-product-card__cta button button--secondary" href="{{ product.url }}">
        {{ cta_label }}
      </a>
    </div>
  </article>
{%- else -%}
  {%- assign placeholder_number = placeholder_index | default: 1 -%}
  {%- assign placeholder_key = 'product-apparel-' | append: placeholder_number -%}
  <article class="sb-product-card">
    <div class="sb-product-card__media">
      {{ placeholder_key | placeholder_svg_tag: 'sb-product-card__placeholder placeholder-svg' }}
    </div>
    <div class="sb-product-card__content">
      <h3 class="sb-product-card__title">Curated product</h3>
      <div class="sb-product-card__price">
        <span class="price">$00.00</span>
      </div>
      <span class="sb-product-card__cta button button--secondary" aria-hidden="true">
        {{ cta_label }}
      </span>
    </div>
  </article>
{%- endif -%}
