{% comment %}
  Reusable brand button.
  Accepts:
  - label: Button text.
  - link: Optional href. When blank and element is link, button is disabled.
  - style: 'primary' or 'secondary'. Defaults to primary.
  - type: Button type for <button>. Defaults to submit.
  - element: 'a' or 'button'. Defaults to a when link is present, otherwise button.
  - class: Optional extra classes.
  - aria_label: Optional accessible label override.
{% endcomment %}
{%- liquid
  assign button_style = style | default: 'primary'
  assign button_element = element
  if button_element == blank
    if link != blank
      assign button_element = 'a'
    else
      assign button_element = 'button'
    endif
  endif

  capture button_class
    echo 'button sb-button'
    if button_style == 'secondary'
      echo ' button--secondary'
    else
      echo ' button--primary'
    endif
    if class != blank
      echo ' '
      echo class
    endif
  endcapture
-%}

{% if button_element == 'button' %}
  <button
    type="{{ type | default: 'submit' }}"
    class="{{ button_class | strip }}"
    {% if aria_label != blank %}
      aria-label="{{ aria_label | escape }}"
    {% endif %}
  >
    {{ label | default: 'SHOP NOW' | escape }}
  </button>
{% else %}
  <a
    {% if link != blank %}
      href="{{ link }}"
    {% else %}
      role="link" aria-disabled="true"
    {% endif %}
    class="{{ button_class | strip }}"
    {% if aria_label != blank %}
      aria-label="{{ aria_label | escape }}"
    {% endif %}
  >
    {{ label | default: 'SHOP NOW' | escape }}
  </a>
{% endif %}
