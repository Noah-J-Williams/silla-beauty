{% comment %}
  Shared editorial heading row used across homepage sections.

  Accepts:
  - eyebrow: Optional eyebrow text
  - heading: Required section heading
  - link_label: Optional trailing link label
  - link_url: Optional trailing link URL
  - modifier: Optional class suffix
{% endcomment %}

<div class="sb-section-heading{% if modifier != blank %} sb-section-heading--{{ modifier }}{% endif %}">
  <div class="sb-section-heading__copy">
    {% if eyebrow != blank %}
      <p class="sb-section-heading__eyebrow">{{ eyebrow }}</p>
    {% endif %}

    {% if heading != blank %}
      <h2 class="sb-section-heading__title">{{ heading }}</h2>
    {% endif %}
  </div>

  {% if link_label != blank and link_url != blank %}
    <a class="sb-section-heading__link" href="{{ link_url }}">
      {{ link_label }}
    </a>
  {% endif %}
</div>
