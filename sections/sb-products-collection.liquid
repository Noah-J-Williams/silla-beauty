{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="sb-section sb-products-collection color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">
    {% render 'sb-section-heading', title: section.settings.heading, text: section.settings.subheading, align: 'left' %}

    <div class="sb-featured-products">
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          <div class="sb-featured-products__item">
            {% render 'sb-product-card', product: product, section_id: section.id, show_secondary_image: section.settings.show_secondary_image, lazy_load: forloop.index > 1, button_label: 'SHOP NOW' %}
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..section.settings.products_to_show) %}
          <article class="sb-product-card sb-product-card--placeholder">
            <div class="sb-product-card__media">{{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg sb-product-card__image' }}</div>
            <div class="sb-product-card__content">
              <p class="sb-product-card__meta">Featured Product</p>
              <h3 class="sb-product-card__title">Product title</h3>
              {% render 'sb-button', label: 'SHOP NOW', link: routes.all_products_collection_url, class: 'sb-product-card__cta' %}
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_view_all and section.settings.collection != blank %}
      <div class="sb-featured-products__footer">
        {% render 'sb-button', label: section.settings.view_all_label, link: section.settings.collection.url, style: 'secondary' %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SB Products Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "null"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all products"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "SB Products Collection"
    }
  ]
}
{% endschema %}
