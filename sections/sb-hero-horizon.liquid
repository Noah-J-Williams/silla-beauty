{%- assign sb_section_spacing_class = 'section-' | append: section.id | append: '-padding' -%}
{% render 'sb-section-spacing', section: section, class_name: sb_section_spacing_class %}

<section class="sb-section sb-hero-horizon color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding{% if section.settings.overlay_gradient %} sb-hero-horizon--overlay{% endif %}">
  <div class="page-width sb-hero-horizon__layout">
    <div class="sb-hero-horizon__content">
      {% if section.settings.badge_text != blank %}
        <span class="sb-pill">{{ section.settings.badge_text }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="sb-hero-horizon__heading rte">{{ section.settings.heading }}</div>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="sb-hero-horizon__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="sb-hero-horizon__actions">
        {% if section.settings.primary_label != blank %}
          {% render 'sb-button', label: section.settings.primary_label, link: section.settings.primary_link %}
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          {% render 'sb-button', label: section.settings.secondary_label, link: section.settings.secondary_link, style: 'secondary' %}
        {% endif %}
      </div>
    </div>

    <div class="sb-hero-horizon__media">
      {% if section.settings.hero_image != blank %}
        <picture>
          {% if section.settings.hero_image_mobile != blank %}
            <source media="(max-width: 749px)" srcset="{{ section.settings.hero_image_mobile | image_url: width: 900 }}">
          {% endif %}
          {{ section.settings.hero_image | image_url: width: 1800 | image_tag: class: 'sb-hero-horizon__image', widths: '480, 720, 960, 1200, 1600, 1800', sizes: '(min-width: 990px) 54vw, 100vw', loading: 'eager', fetchpriority: 'high', alt: section.settings.hero_image.alt | default: shop.name | escape }}
        </picture>
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'sb-hero-horizon__image placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SB Hero Horizon",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Clinical Aesthetics<br><em>for glowing skin</em></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience advanced skincare and beauty treatments tailored for radiant results."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "null"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "null"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image (mobile)"
    },
    {
      "type": "checkbox",
      "id": "overlay_gradient",
      "label": "Enable overlay gradient",
      "default": true
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Trust bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Licensed estheticians · Calm, private suites"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "SB Hero Horizon",
      "blocks": [
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        }
      ]
    }
  ]
}
{% endschema %}
