{%- assign spacing_class = 'section-' | append: section.id | append: '-padding' -%}
{% render 'sb-section-spacing', section: section, class_name: spacing_class %}

<section class="sb-home-section sb-skin-protocols {{ spacing_class }}">
  <div class="page-width">
    <div class="sb-skin-protocols__shell">
      {% if section.settings.heading != blank %}
        <h2 class="sb-skin-protocols__title">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="sb-skin-protocols__grid">
      {% for block in section.blocks %}
        {%- assign has_second_image = false -%}
        {% if block.settings.image_2 != blank %}
          {%- assign has_second_image = true -%}
        {% endif %}
        <article class="sb-protocol-card" {{ block.shopify_attributes }}>
          <div class="sb-protocol-card__copy">
            {% if block.settings.concern_title != blank %}
              <h3 class="sb-protocol-card__title">{{ block.settings.concern_title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="sb-protocol-card__description">{{ block.settings.description }}</p>
            {% endif %}
          </div>

          <div class="sb-protocol-card__media-grid{% unless has_second_image %} is-single{% endunless %}">
            {% if block.settings.image_1 != blank %}
              <div class="sb-protocol-card__media">
                {{
                  block.settings.image_1
                  | image_url: width: 900
                  | image_tag:
                    widths: '260, 360, 520, 720, 900',
                    sizes: '(min-width: 750px) calc((100vw - 8rem) / 4), calc((100vw - 5rem) / 2)',
                    loading: 'lazy',
                    alt: block.settings.concern_title | escape
                }}
              </div>
            {% else %}
              <div class="sb-protocol-card__media">
                <div class="sb-protocol-card__placeholder"></div>
              </div>
            {% endif %}

            {% if has_second_image %}
              <div class="sb-protocol-card__media">
                {{
                  block.settings.image_2
                  | image_url: width: 900
                  | image_tag:
                    widths: '260, 360, 520, 720, 900',
                    sizes: '(min-width: 750px) calc((100vw - 8rem) / 4), calc((100vw - 5rem) / 2)',
                    loading: 'lazy',
                    alt: block.settings.concern_title | escape
                }}
              </div>
            {% endif %}
          </div>

          {% if block.settings.button_label != blank and block.settings.button_link != blank %}
            <a class="sb-protocol-card__button button button--secondary" href="{{ block.settings.button_link }}">{{ block.settings.button_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SB Protocols Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Protocols for skin concerns"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "concern_title",
          "label": "Concern title",
          "default": "Hyperpigmentation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "Support a clearer-looking, more even complexion with a focused edit."
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop concern"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SB Protocols Grid",
      "blocks": [
        {
          "type": "concern"
        },
        {
          "type": "concern"
        },
        {
          "type": "concern"
        },
        {
          "type": "concern"
        }
      ]
    }
  ]
}
{% endschema %}
