<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --sb-header-logo-width: {{ section.settings.logo_width }}px;
    --sb-header-padding-top-mobile: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    --sb-header-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    --sb-header-padding-top-desktop: {{ section.settings.padding_top }}px;
    --sb-header-padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{%- liquid
  assign shop_columns_count = 0
  assign booking_links_count = 0

  for block in section.blocks
    case block.type
      when 'shop_column'
        assign shop_columns_count = shop_columns_count | plus: 1
      when 'booking_link'
        assign booking_links_count = booking_links_count | plus: 1
    endcase
  endfor

  assign best_sellers_url = section.settings.best_sellers_link | default: routes.all_products_collection_url
  assign about_url = section.settings.about_link | default: '/pages/about'
-%}

<div class="sb-header{% if section.settings.sticky_header %} sb-header--sticky{% endif %}">
  <div class="sb-header__inner">
    <header class="sb-header__topbar" role="banner" data-sb-header-bar>
      <div class="sb-header__left">
        <button
          class="sb-header__icon-button sb-header__menu-toggle medium-hide large-up-hide"
          type="button"
          data-sb-drawer-open
          aria-expanded="false"
          aria-controls="SillaMobileDrawer-{{ section.id }}"
          aria-label="{{ 'sections.header.menu' | t }}"
        >
          <span class="svg-wrapper">{{ 'icon-hamburger.svg' | inline_asset_content }}</span>
        </button>

        {%- if section.settings.show_search -%}
          {% render 'header-search', input_id: 'Search-In-Modal' %}
        {%- endif -%}
      </div>

      {%- if request.page_type == 'index' -%}
        <h1 class="sb-header__logo">
      {%- else -%}
        <div class="sb-header__logo">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="sb-header__logo-link focus-inset">
            {%- if settings.logo != blank -%}
              {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
              {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
              {{
                settings.logo
                | image_url: width: 600
                | image_tag:
                  class: 'sb-header__logo-mark',
                  widths: '180, 240, 320, 420, 520, 600',
                  sizes: '(min-width: 990px) 240px, 42vw',
                  alt: logo_alt,
                  height: logo_height,
                  width: section.settings.logo_width,
                  preload: true
              }}
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- else -%}
        </div>
      {%- endif -%}

      <div class="sb-header__right">
        {%- if shop.customer_accounts_enabled and section.settings.show_account_icon -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header__icon header__icon--account link focus-inset"
            rel="nofollow"
          >
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
            <span class="visually-hidden">
              {%- if customer -%}
                {{ 'customer.account_fallback' | t }}
              {%- else -%}
                {{ 'customer.log_in' | t }}
              {%- endif -%}
            </span>
          </a>
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
          {% if cart == empty %}
            <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
          {% else %}
            <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
          {% endif %}
          <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
          {%- if cart != empty -%}
            <div class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          {%- endif -%}
        </a>
      </div>
    </header>

    <nav class="sb-header__nav" aria-label="Primary">
      <ul class="sb-header__nav-list" role="list">
        <li class="sb-header__nav-item sb-header__nav-item--shop">
          {% if shop_columns_count > 0 %}
            <details>
              <summary class="sb-header__nav-summary">
                {{ section.settings.shop_label | escape }}
                <span class="sb-header__nav-plus">+</span>
              </summary>
              <div class="sb-header__panel sb-header__mega-panel">
                <div class="sb-header__panel-inner">
                  <div class="sb-header__mega-columns">
                    {% for block in section.blocks %}
                      {% if block.type == 'shop_column' %}
                        {%- assign fallback_items = block.settings.fallback_items | newline_to_br | split: '<br />' -%}
                        <div class="sb-header__mega-column" {{ block.shopify_attributes }}>
                          {% if block.settings.heading_link != blank %}
                            <a class="sb-header__mega-heading" href="{{ block.settings.heading_link }}">{{ block.settings.heading | escape }}</a>
                          {% else %}
                            <p class="sb-header__mega-heading">{{ block.settings.heading | escape }}</p>
                          {% endif %}

                          {% if block.settings.menu != blank and block.settings.menu.links.size > 0 %}
                            <ul class="sb-header__mega-links" role="list">
                              {% for menu_link in block.settings.menu.links %}
                                <li><a href="{{ menu_link.url }}">{{ menu_link.title | escape }}</a></li>
                              {% endfor %}
                            </ul>
                          {% elsif block.settings.fallback_items != blank %}
                            <ul class="sb-header__mega-links" role="list">
                              {% for item in fallback_items %}
                                {%- assign item_label = item | strip -%}
                                {% if item_label != blank %}
                                  {% if block.settings.link_fallback_items %}
                                    {%- assign item_handle = item_label | handleize -%}
                                    {%- assign item_url = routes.collections_url | append: '/' | append: item_handle -%}
                                    <li><a href="{{ item_url }}">{{ item_label | escape }}</a></li>
                                  {% else %}
                                    <li><span class="sb-header__mega-text">{{ item_label | escape }}</span></li>
                                  {% endif %}
                                {% endif %}
                              {% endfor %}
                            </ul>
                          {% endif %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </details>
          {% else %}
            <a href="{{ routes.all_products_collection_url }}" class="sb-header__nav-link">{{ section.settings.shop_label | escape }}</a>
          {% endif %}
        </li>

        <li class="sb-header__nav-item sb-header__nav-item--basic">
          <a href="{{ best_sellers_url }}" class="sb-header__nav-link">{{ section.settings.best_sellers_label | escape }}</a>
        </li>

        <li class="sb-header__nav-item sb-header__nav-item--booking">
          {% if booking_links_count > 0 %}
            <details>
              <summary class="sb-header__nav-summary">
                {{ section.settings.booking_label | escape }}
                <span class="sb-header__nav-plus">+</span>
              </summary>
              <div class="sb-header__panel sb-header__dropdown-panel">
                <div class="sb-header__panel-inner">
                  <ul class="sb-header__dropdown-list" role="list">
                    {% for block in section.blocks %}
                      {% if block.type == 'booking_link' %}
                        <li {{ block.shopify_attributes }}>
                          {% if block.settings.link != blank %}
                            <a href="{{ block.settings.link }}">{{ block.settings.label | escape }}</a>
                          {% else %}
                            <span class="sb-header__dropdown-text">{{ block.settings.label | escape }}</span>
                          {% endif %}
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
            </details>
          {% else %}
            <a href="/pages/contact" class="sb-header__nav-link">{{ section.settings.booking_label | escape }}</a>
          {% endif %}
        </li>

        <li class="sb-header__nav-item sb-header__nav-item--basic">
          <a href="{{ about_url }}" class="sb-header__nav-link">{{ section.settings.about_label | escape }}</a>
        </li>
      </ul>
    </nav>

    <div class="sb-header__mobile-drawer medium-hide large-up-hide" id="SillaMobileDrawer-{{ section.id }}" data-sb-drawer>
      <button class="sb-header__mobile-overlay" type="button" data-sb-drawer-close aria-label="Close menu"></button>
      <div class="sb-header__mobile-panel" role="dialog" aria-modal="true" aria-label="Mobile menu">
        <div class="sb-header__mobile-head">
          <span class="sb-header__mobile-title">Menu</span>
          <button class="sb-header__mobile-close" type="button" data-sb-drawer-close aria-label="Close menu">
            <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
          </button>
        </div>

        <nav aria-label="Mobile">
          <ul class="sb-header__mobile-menu" role="list">
            <li class="sb-header__mobile-item">
              <details>
                <summary class="sb-header__mobile-summary">
                  {{ section.settings.shop_label | escape }}
                  <span class="sb-header__mobile-plus">+</span>
                </summary>
                <ul class="sb-header__mobile-submenu" role="list">
                  {% for block in section.blocks %}
                    {% if block.type == 'shop_column' %}
                      {%- assign fallback_items = block.settings.fallback_items | newline_to_br | split: '<br />' -%}
                      <li {{ block.shopify_attributes }}>
                        {% if block.settings.heading_link != blank %}
                          <a class="sb-header__mobile-column-heading" href="{{ block.settings.heading_link }}">{{ block.settings.heading | escape }}</a>
                        {% else %}
                          <span class="sb-header__mobile-column-heading">{{ block.settings.heading | escape }}</span>
                        {% endif %}

                        {% if block.settings.menu != blank and block.settings.menu.links.size > 0 %}
                          <ul class="sb-header__mobile-sublist" role="list">
                            {% for menu_link in block.settings.menu.links %}
                              <li><a href="{{ menu_link.url }}">{{ menu_link.title | escape }}</a></li>
                            {% endfor %}
                          </ul>
                        {% elsif block.settings.link_fallback_items and block.settings.fallback_items != blank %}
                          <ul class="sb-header__mobile-sublist" role="list">
                            {% for item in fallback_items %}
                              {%- assign item_label = item | strip -%}
                              {% if item_label != blank %}
                                {%- assign item_handle = item_label | handleize -%}
                                {%- assign item_url = routes.collections_url | append: '/' | append: item_handle -%}
                                <li><a href="{{ item_url }}">{{ item_label | escape }}</a></li>
                              {% endif %}
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </details>
            </li>

            <li class="sb-header__mobile-item">
              <a class="sb-header__mobile-link" href="{{ best_sellers_url }}">{{ section.settings.best_sellers_label | escape }}</a>
            </li>

            <li class="sb-header__mobile-item">
              <details>
                <summary class="sb-header__mobile-summary">
                  {{ section.settings.booking_label | escape }}
                  <span class="sb-header__mobile-plus">+</span>
                </summary>
                <ul class="sb-header__mobile-submenu" role="list">
                  {% for block in section.blocks %}
                    {% if block.type == 'booking_link' %}
                      <li {{ block.shopify_attributes }}>
                        {% if block.settings.link != blank %}
                          <a href="{{ block.settings.link }}">{{ block.settings.label | escape }}</a>
                        {% else %}
                          <span>{{ block.settings.label | escape }}</span>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </details>
            </li>

            <li class="sb-header__mobile-item">
              <a class="sb-header__mobile-link" href="{{ about_url }}">{{ section.settings.about_label | escape }}</a>
            </li>
          </ul>

          {%- if shop.customer_accounts_enabled and section.settings.show_account_icon -%}
            <a
              href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
              class="button sb-header__mobile-account"
              rel="nofollow"
            >
              {%- if customer -%}
                {{ 'customer.account_fallback' | t }}
              {%- else -%}
                {{ 'customer.log_in' | t }}
              {%- endif -%}
            </a>
          {%- endif -%}
        </nav>
      </div>
    </div>
  </div>
</div>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: 'scheme-1', desktop_menu_type: 'dropdown' -%}
{%- endif -%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "class": "section-header sb-header-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account_icon",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop label",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "best_sellers_label",
      "label": "Best sellers label",
      "default": "Best Sellers"
    },
    {
      "type": "url",
      "id": "best_sellers_link",
      "label": "Best sellers link"
    },
    {
      "type": "text",
      "id": "booking_label",
      "label": "Booking label",
      "default": "Booking"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "About label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About link"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 120,
      "max": 320,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 260
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Top bar padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Top bar padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "shop_column",
      "name": "Shop column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "By category"
        },
        {
          "type": "url",
          "id": "heading_link",
          "label": "Heading link"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "textarea",
          "id": "fallback_items",
          "label": "Fallback items",
          "info": "Use one item per line when no menu is assigned.",
          "default": "Cleansers\nSerums\nMoisturisers\nActives\nToners\nEye Care\nLip Care\nBody Care\nSunscreens"
        },
        {
          "type": "checkbox",
          "id": "link_fallback_items",
          "label": "Link fallback items to collection pages",
          "default": false
        }
      ]
    },
    {
      "type": "booking_link",
      "name": "Booking link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Book Online"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}

