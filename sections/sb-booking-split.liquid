{%- assign spacing_class = 'section-' | append: section.id | append: '-padding' -%}
{% render 'sb-section-spacing', section: section, class_name: spacing_class %}

<section class="sb-home-section sb-booking-split {{ spacing_class }}">
  <div class="page-width">
    <div class="sb-booking-split__layout">
      <div class="sb-booking-split__copy">
        {% if section.settings.eyebrow != blank %}
          <p class="sb-booking-split__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="sb-booking-split__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.body_copy != blank %}
          <div class="sb-booking-split__body rte">{{ section.settings.body_copy }}</div>
        {% endif %}

        {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
          <div class="sb-booking-split__actions">
            {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
              <a class="button" href="{{ section.settings.primary_button_link }}">{{ section.settings.primary_button_label }}</a>
            {% endif %}
            {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
              <a class="button button--secondary" href="{{ section.settings.secondary_button_link }}">{{ section.settings.secondary_button_label }}</a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="sb-booking-split__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              widths: '720, 960, 1280, 1600',
              sizes: '(min-width: 990px) calc((100vw - 10rem) / 2), 100vw',
              loading: 'lazy',
              alt: section.settings.heading | escape
          }}
        {% else %}
          <div class="sb-booking-split__placeholder"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SB Booking Split",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Book consultations"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Visit our Alberton studio or book virtually"
    },
    {
      "type": "richtext",
      "id": "body_copy",
      "label": "Body copy",
      "default": "<p>Schedule an in-studio facial experience or a guided virtual consultation to build a routine around your goals.</p>"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Book appointment"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Book virtual consult"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "SB Booking Split"
    }
  ]
}
{% endschema %}
