{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign footer_logo = section.settings.logo | default: settings.logo
  assign footer_logo_alt = footer_logo.alt | default: shop.name | escape
  capture footer_logo_sizes
    echo '(min-width: 990px) '
    echo section.settings.logo_width
    echo 'px, 72vw'
  endcapture
  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif
-%}

<footer class="footer sb-footer section-{{ section.id }}-padding" style="--sb-footer-logo-width: {{ section.settings.logo_width }}px;">
  <div class="sb-footer__inner">
    <div class="sb-footer__brand">
      {% if footer_logo != blank %}
        <a class="sb-footer__brand-mark" href="{{ routes.root_url }}">
          {{
            footer_logo
            | image_url: width: 720
            | image_tag:
              widths: '220, 320, 420, 520, 720',
              sizes: footer_logo_sizes,
              loading: 'lazy',
              alt: footer_logo_alt
          }}
        </a>
      {% else %}
        <a class="sb-footer__brand-mark sb-footer__brand-mark--text" href="{{ routes.root_url }}">{{ shop.name }}</a>
      {% endif %}

      {% if section.settings.intro_text != blank %}
        <div class="sb-footer__brand-copy rte">{{ section.settings.intro_text }}</div>
      {% endif %}
    </div>

    <div class="sb-footer__newsletter" aria-labelledby="FooterNewsletterHeading-{{ section.id }}">
      {% if section.settings.newsletter_heading != blank %}
        <h2 class="sb-footer__newsletter-heading" id="FooterNewsletterHeading-{{ section.id }}">{{ section.settings.newsletter_heading }}</h2>
      {% endif %}

      {% if section.settings.newsletter_body != blank %}
        <div class="sb-footer__newsletter-copy rte">{{ section.settings.newsletter_body }}</div>
      {% endif %}

      {%- form 'customer', class: 'sb-footer__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="sb-footer__field-shell">
          <label class="visually-hidden" for="FooterNewsletter-{{ section.id }}">{{ section.settings.email_placeholder }}</label>
          <input
            id="FooterNewsletter-{{ section.id }}"
            class="sb-footer__input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="FooterNewsletter-{{ section.id }}-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="FooterNewsletter-{{ section.id }}-success"
            {% endif %}
            placeholder="{{ section.settings.email_placeholder }}"
            required
          >
          <button class="sb-footer__submit" type="submit" name="commit">{{ section.settings.newsletter_button_label }}</button>
        </div>

        {% if form.errors %}
          <small class="newsletter-form__message form__message" id="FooterNewsletter-{{ section.id }}-error">
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </small>
        {% endif %}

        {% if form.posted_successfully? %}
          <p class="newsletter-form__message newsletter-form__message--success form__message" id="FooterNewsletter-{{ section.id }}-success" tabindex="-1" autofocus>
            {{ 'newsletter.success' | t }}
          </p>
        {% endif %}
      {%- endform -%}
    </div>

    <div class="sb-footer__menus" role="navigation" aria-label="Footer menus">
      <details class="sb-footer__accordion" {% if section.settings.expand_menus_by_default %}open{% endif %}>
        <summary class="sb-footer__summary">
          <span>{{ section.settings.shop_heading }}</span>
          <span class="sb-footer__summary-plus" aria-hidden="true">+</span>
        </summary>
        <div class="sb-footer__accordion-body">
          <ul class="sb-footer__menu" role="list">
            {% for link in section.settings.shop_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </details>

      <details class="sb-footer__accordion" {% if section.settings.expand_menus_by_default %}open{% endif %}>
        <summary class="sb-footer__summary">
          <span>{{ section.settings.help_heading }}</span>
          <span class="sb-footer__summary-plus" aria-hidden="true">+</span>
        </summary>
        <div class="sb-footer__accordion-body">
          <ul class="sb-footer__menu" role="list">
            {% for link in section.settings.help_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </details>
    </div>

    <div class="sb-footer__contact">
      {% if section.settings.contact_heading != blank %}
        <h2 class="sb-footer__contact-heading">{{ section.settings.contact_heading }}</h2>
      {% endif %}

      <address class="sb-footer__contact-copy">
        {% if section.settings.business_hours != blank %}
          <p>{{ section.settings.business_hours | newline_to_br }}</p>
        {% endif %}
        {% if section.settings.address != blank %}
          <p>{{ section.settings.address | newline_to_br }}</p>
        {% endif %}
        {% if section.settings.email != blank %}
          <p>
            {% if section.settings.email_label != blank %}{{ section.settings.email_label }}:{% endif %}
            <a href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email }}</a>
          </p>
        {% endif %}
      </address>

      {% if section.settings.show_social and has_social_icons %}
        <div class="sb-footer__social-wrap">
          {% if section.settings.social_heading != blank %}
            <p class="sb-footer__social-heading">{{ section.settings.social_heading }}</p>
          {% endif %}
          <div class="sb-footer__social">
            {% render 'social-icons', class: 'footer__list-social' %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 160,
      "max": 360,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 260
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text",
      "default": "<p>Courtney Gaudette is a Clinical Aesthetician specializing in results-driven skin protocols, trusted by private clientele.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join the Silla Beauty newsletter"
    },
    {
      "type": "richtext",
      "id": "newsletter_body",
      "label": "Newsletter body",
      "default": "<p>Never miss a thing. Expert skin guidance, monthly edits and first access to new launches.</p>"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter email"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Newsletter button label",
      "default": "Join the list"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "Shop heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "help_heading",
      "label": "Help heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "Help menu",
      "default": "footer"
    },
    {
      "type": "checkbox",
      "id": "expand_menus_by_default",
      "label": "Expand menus by default",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact us"
    },
    {
      "type": "textarea",
      "id": "business_hours",
      "label": "Business hours",
      "default": "Tuesday - Friday 10:00 AM - 5:00 PM"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "460 Main Street, Alberton, PE C0B 1B0"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@sillabeauty.ca"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Follow Silla Beauty"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    }
  ]
}
{% endschema %}

