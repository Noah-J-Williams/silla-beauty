{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- assign sb_section_spacing_class = 'section-' | append: section.id | append: '-padding' -%}
{% render 'sb-section-spacing', section: section, class_name: sb_section_spacing_class %}

{%- liquid
  assign rendered_products = 0
  assign rendered_handles = '|'
  assign structured_item_position = 0
-%}
{%- capture structured_items -%}{%- endcapture -%}

<section class="sb-home-product-grid color-{{ section.settings.color_scheme }} {{ sb_section_spacing_class }}">
  <div class="page-width">
    <div class="sb-home-product-grid__header">
      {% if section.settings.eyebrow != blank %}
        <p class="sb-home-kicker">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="sb-home-product-grid__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="sb-home-copy">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sb-home-product-grid__products">
      {% comment %}
        Render any hand-picked products first, then top up from the fallback
        collection so the grid stays complete without extra merchant work.
      {% endcomment %}
      {% for block in section.blocks %}
        {% if rendered_products >= section.settings.products_to_show %}
          {% break %}
        {% endif %}

        {% if block.settings.product != blank %}
          {% assign manual_product = block.settings.product %}
          {% assign product_token = '|' | append: manual_product.handle | append: '|' %}

          {% unless rendered_handles contains product_token %}
            {% assign rendered_products = rendered_products | plus: 1 %}
            {% assign rendered_handles = rendered_handles | append: manual_product.handle | append: '|' %}
            {% assign product_loading = 'lazy' %}
            {% if rendered_products <= 2 %}
              {% assign product_loading = 'eager' %}
            {% endif %}
            {% assign current_variant = manual_product.selected_or_first_available_variant %}
            {% assign item_availability = 'https://schema.org/OutOfStock' %}
            {% if current_variant != blank and current_variant.available %}
              {% assign item_availability = 'https://schema.org/InStock' %}
            {% endif %}
            {% assign structured_item_position = structured_item_position | plus: 1 %}
            {% capture structured_item %}
              {
                "@type": "ListItem",
                "position": {{ structured_item_position }},
                "url": {{ request.origin | append: manual_product.url | json }},
                "item": {
                  "@type": "Product",
                  "name": {{ manual_product.title | json }},
                  "url": {{ request.origin | append: manual_product.url | json }}{% if manual_product.featured_media != blank %},
                  "image": {{ manual_product.featured_media | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}{% if current_variant != blank %},
                  "offers": {
                    "@type": "Offer",
                    "priceCurrency": {{ cart.currency.iso_code | json }},
                    "price": {{ current_variant.price | divided_by: 100.0 | json }},
                    "availability": {{ item_availability | json }}
                  }{% endif %}
                }
              }
            {% endcapture %}
            {% if structured_items != blank %}
              {% capture structured_items %}{{ structured_items }},{{ structured_item | strip }}{% endcapture %}
            {% else %}
              {% capture structured_items %}{{ structured_item | strip }}{% endcapture %}
            {% endif %}

            <div {{ block.shopify_attributes }}>
              {% render 'sb-home-product-card',
                product: manual_product,
                loading: product_loading
              %}
            </div>
          {% endunless %}
        {% endif %}
      {% endfor %}

      {% if rendered_products < section.settings.products_to_show and section.settings.collection != blank %}
        {% for product in section.settings.collection.products %}
          {% if rendered_products >= section.settings.products_to_show %}
            {% break %}
          {% endif %}

          {% assign product_token = '|' | append: product.handle | append: '|' %}

          {% unless rendered_handles contains product_token %}
            {% assign rendered_products = rendered_products | plus: 1 %}
            {% assign rendered_handles = rendered_handles | append: product.handle | append: '|' %}
            {% assign product_loading = 'lazy' %}
            {% if rendered_products <= 2 %}
              {% assign product_loading = 'eager' %}
            {% endif %}
            {% assign current_variant = product.selected_or_first_available_variant %}
            {% assign item_availability = 'https://schema.org/OutOfStock' %}
            {% if current_variant != blank and current_variant.available %}
              {% assign item_availability = 'https://schema.org/InStock' %}
            {% endif %}
            {% assign structured_item_position = structured_item_position | plus: 1 %}
            {% capture structured_item %}
              {
                "@type": "ListItem",
                "position": {{ structured_item_position }},
                "url": {{ request.origin | append: product.url | json }},
                "item": {
                  "@type": "Product",
                  "name": {{ product.title | json }},
                  "url": {{ request.origin | append: product.url | json }}{% if product.featured_media != blank %},
                  "image": {{ product.featured_media | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}{% if current_variant != blank %},
                  "offers": {
                    "@type": "Offer",
                    "priceCurrency": {{ cart.currency.iso_code | json }},
                    "price": {{ current_variant.price | divided_by: 100.0 | json }},
                    "availability": {{ item_availability | json }}
                  }{% endif %}
                }
              }
            {% endcapture %}
            {% if structured_items != blank %}
              {% capture structured_items %}{{ structured_items }},{{ structured_item | strip }}{% endcapture %}
            {% else %}
              {% capture structured_items %}{{ structured_item | strip }}{% endcapture %}
            {% endif %}

            {% render 'sb-home-product-card',
              product: product,
              loading: product_loading
            %}
          {% endunless %}
        {% endfor %}
      {% endif %}

      {% if rendered_products == 0 %}
        {% for i in (1..section.settings.products_to_show) %}
          {% assign placeholder_number = forloop.index %}
          {% if placeholder_number > 6 %}
            {% assign placeholder_number = 6 %}
          {% endif %}

          {% render 'sb-home-product-card', placeholder_index: placeholder_number %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.view_all_label != blank and section.settings.collection != blank %}
      <div class="sb-home-product-grid__footer">
        <a class="button button--secondary" href="{{ section.settings.collection.url }}">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% if request.page_type == 'index' and structured_item_position > 0 %}
  {% comment %}
    Mirror the curated 6-product grid in schema so search engines see the same
    product order customers see on the homepage.
  {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": {{ section.settings.heading | default: 'Best-selling skincare and studio favorites' | json }},
      "numberOfItems": {{ structured_item_position }},
      "itemListOrder": "https://schema.org/ItemListOrderAscending",
      "itemListElement": [{{ structured_items }}]
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "SB Home Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best-selling skincare and studio favorites"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Supporting text",
      "default": "A curated six-product edit for daily ritual."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 6
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "VIEW ALL PRODUCTS"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "SB Home Product Grid",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
